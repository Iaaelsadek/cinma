# ==========================================
# 🎬 4CIMA - Environment Variables
# Copy this file to .env and fill in values
# ==========================================

# ------------------------------------------
# Site Settings
# ------------------------------------------
VITE_SITE_NAME="فور سيما"
VITE_DOMAIN="4cima.com"
VITE_SITE_URL="https://4cima.com"

# ------------------------------------------
# Supabase (Auth & User Data ONLY)
# ⚠️ NEVER use Supabase for content/movies
# ------------------------------------------
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# ------------------------------------------
# CockroachDB (ALL Content - Movies, Series, etc.)
# ⚠️ This is the PRIMARY database for all content
# ------------------------------------------
COCKROACHDB_URL="postgresql://user:password@host:26257/defaultdb?sslmode=verify-full"

# ------------------------------------------
# TMDB API (Content ingestion only)
# ------------------------------------------
VITE_TMDB_API_KEY="your_tmdb_api_key"
TMDB_API_KEY="your_tmdb_api_key"

# ------------------------------------------
# 🤖 AI APIs
# ------------------------------------------

# Groq AI (Summaries, Recommendations, Chat)
GROQ_API_KEY="your_groq_api_key"
VITE_GROQ_API_KEY="your_groq_api_key"

# Mistral AI (Arabic Translation - Backup)
MISTRAL_API_KEY="your_mistral_api_key"

# ------------------------------------------
# Server Settings
# ------------------------------------------
PORT=3001
NODE_ENV="development"
HOST="0.0.0.0"
ADMIN_SYNC_TOKEN="your_random_32_char_token_here"
WEB_ORIGIN="https://4cima.com"

# ------------------------------------------
# API Configuration
# Development: http://localhost:3001
# Production: https://your-qovery-app.koyeb.app
# ------------------------------------------
VITE_API_URL="http://localhost:3001"
VITE_API_BASE="http://localhost:3001"
API_KEY="your_api_key_here"
VITE_API_KEY="your_api_key_here"

# ------------------------------------------
# Cloudflare (Frontend deployment)
# ------------------------------------------
# CLOUDFLARE_API_TOKEN - Set in GitHub Secrets
# CLOUDFLARE_ACCOUNT_ID - Set in GitHub Secrets

# ------------------------------------------
# Qovery (Backend deployment)
# ------------------------------------------
# QOVERY_TOKEN - Set in GitHub Secrets
# QOVERY_ORG_ID - Set in GitHub Secrets
# QOVERY_PROJECT_ID - Set in GitHub Secrets
# QOVERY_ENV_ID - Set in GitHub Secrets
