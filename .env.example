# ==========================================
# 🎬 CINMA.ONLINE - Environment Variables
# Copy this file to .env.local and fill in values
# ==========================================

# ------------------------------------------
# Site Settings
# ------------------------------------------
VITE_SITE_NAME="اونلاين سينما"
VITE_DOMAIN="cinma.online"
VITE_SITE_URL="https://cinma.online"

# ------------------------------------------
# Android App Settings
# ------------------------------------------
VITE_APK_DOWNLOAD_URL="/downloads/online-cinema.apk"

# ------------------------------------------
# Supabase (Auth Only)
# ------------------------------------------
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# ------------------------------------------
# CockroachDB (Main Database)
# ------------------------------------------
COCKROACHDB_URL="postgresql://user:password@host:26257/defaultdb?sslmode=verify-full"
# Certificate auto-detected from: ~/.postgresql/root.crt or AppData/Roaming/postgresql/root.crt

# ------------------------------------------
# TMDB (Images & Data)
# ------------------------------------------
VITE_TMDB_API_KEY="your_tmdb_api_key"
TMDB_API_KEY="your_tmdb_api_key"

# ------------------------------------------
# Groq AI (Chatbot)
# ------------------------------------------
GROQ_API_KEY="your_groq_api_key"
VITE_GROQ_API_KEY="your_groq_api_key"

# ------------------------------------------
# Gemini AI (Primary Chatbot)
# ------------------------------------------
GEMINI_API_KEY="your_gemini_api_key"
VITE_GEMINI_API_KEY="your_gemini_api_key"

# ------------------------------------------
# Mistral AI (Fallback)
# ------------------------------------------
MISTRAL_API_KEY="your_mistral_api_key"
VITE_MISTRAL_API_KEY="your_mistral_api_key"
GEMINI_API_KEY="your_gemini_api_key"

# ------------------------------------------
# YouTube API (Trailers)
# ------------------------------------------
VITE_YOUTUBE_API_KEY="your_youtube_api_key"

# ------------------------------------------
# Google OAuth
# ------------------------------------------
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ------------------------------------------
# Server Settings
# ------------------------------------------
PORT=3001
NODE_ENV="development"
ADMIN_SYNC_TOKEN="your_random_32_char_token_here"
ADMIN_CLAIM_TOKEN="your_random_claim_token"
WEB_ORIGIN="https://cinma.online"

# ------------------------------------------
# API Configuration (CRITICAL FOR PRODUCTION)
# ------------------------------------------
# Frontend API URL - Points to your backend server
# Development: http://localhost:3001
# Production: https://your-backend-domain.com (e.g., https://api.cinma.online)
VITE_API_URL="http://localhost:3001"

# App URL - Your frontend domain
# Development: http://localhost:5173
# Production: https://cinma.online
VITE_APP_URL="http://localhost:5173"
