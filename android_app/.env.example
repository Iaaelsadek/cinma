# .env.example - Rename to .env and fill in your values

# Supabase (Auth only)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# API Keys
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-key
EXPO_PUBLIC_TMDB_API_KEY=your-tmdb-key
EXPO_PUBLIC_GROQ_API_KEY=your-groq-key

# Web API (CockroachDB via server)
EXPO_PUBLIC_SITE_URL=https://cinma.online
EXPO_PUBLIC_API_URL=https://cinma.online/api
