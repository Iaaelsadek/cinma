{
  "name": "4cima",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "migration:schema": "node scripts/migration/run_schema.mjs",
    "migration:import": "node scripts/migration/fast_import.mjs",
    "migration:indexes": "node scripts/migration/add_search_indexes.mjs",
    "migration:validate": "node scripts/migration/validate_migration.mjs",
    "migration:reexport": "node scripts/migration/reexport_movies.mjs",
    "tmdb:quick": "node scripts/tmdb/quick_import.mjs",
    "tmdb:medium": "node scripts/tmdb/medium_import.mjs",
    "tmdb:bulk": "node scripts/tmdb/bulk_import.mjs",
    "slugs:add": "tsx scripts/cockroach-add-slugs.ts",
    "slugs:generate": "tsx scripts/cockroach-generate-slugs.ts",
    "slugs:validate": "tsx scripts/cockroach-validate-slugs.ts",
    "slugs:indexes": "tsx scripts/cockroach-add-indexes.ts",
    "dev": "vite",
    "dev:server": "node server/index.js",
    "server": "node server/index.js",
    "worker": "node server/workers/auto-process-requests.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "concurrently \"npm:server\" \"npm:dev\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "audit:full": "tsx src/audit/cli.ts full",
    "audit:code": "tsx src/audit/cli.ts code",
    "audit:security": "tsx src/audit/cli.ts security",
    "audit:report": "tsx src/audit/cli.ts report",
    "audit:status": "tsx src/audit/cli.ts status",
    "validate-env": "node -e \"require('./src/lib/validateEnv.ts')\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "test:smoke": "node scripts/test/production_smoke_test.mjs",
    "test:security": "node scripts/test/security_audit.mjs",
    "test:accessibility": "node scripts/test/accessibility_audit.mjs",
    "test:all": "node scripts/test/run_all_tests.mjs",
    "test:production": "node scripts/test/run_all_tests.mjs --url https://4cima.com",
    "check:all": "npm run typecheck && npm run lint && npm run build",
    "deploy:check": "npm run check:all && npm run test:smoke"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@libsql/client": "^0.17.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@sentry/react": "^10.45.0",
    "@supabase/supabase-js": "^2.45.1",
    "@tanstack/react-query": "^5.50.0",
    "@types/date-fns": "^2.5.3",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "framer-motion": "^11.18.2",
    "groq-sdk": "^0.7.0",
    "isomorphic-dompurify": "^3.5.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.460.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "openai": "^6.34.0",
    "p-limit": "^7.3.0",
    "pg": "^8.18.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.0",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-infinite-scroll-component": "^6.1.0",
    "react-player": "^2.16.1",
    "react-router-dom": "^7.13.0",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.7.0",
    "slugify": "^1.6.9",
    "sonner": "^2.0.7",
    "swagger-ui-express": "^5.0.1",
    "swiper": "^12.1.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-rtl": "^0.9.0",
    "transliteration": "^2.6.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.0",
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.19",
    "canvas": "^3.2.2",
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.35.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.6.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.3.2",
    "postcss": "^8.4.38",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-pwa": "^0.19.8",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.1.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,css,md,json}": [
      "npm run lint:fix",
      "npm run format"
    ]
  },
  "overrides": {
    "serialize-javascript": "^7.0.4",
    "cookie": "^1.1.1"
  }
}
